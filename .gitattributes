# Normalize line endings for all text files
* text=auto

# Force LF for these types (consistent cross-platform)
*.md    text eol=lf
*.php   text eol=lf
*.xml   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.less  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf

# Binary files — no line ending conversion
*.zip   binary
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.ttf   binary
*.woff  binary
*.woff2 binary
